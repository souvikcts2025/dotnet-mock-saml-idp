@model MockSamlIdp.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Mock IdP — Sign In</title>
    <style>
        body { font-family: Segoe UI, sans-serif; background: #f3f4f6; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,.12); width: 340px; }
        h1 { font-size: 1.25rem; margin-bottom: 1.5rem; color: #111; }
        label { display: block; font-size: .85rem; color: #444; margin-bottom: .25rem; }
        input[type=email], input[type=password] { width: 100%; padding: .5rem .75rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; box-sizing: border-box; margin-bottom: 1rem; }
        button { width: 100%; padding: .6rem; background: #0078d4; color: white; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
        button:hover { background: #106ebe; }
        .error { color: #c0392b; font-size: .875rem; margin-bottom: 1rem; }
        .notice { background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: .5rem .75rem; font-size: .8rem; margin-bottom: 1rem; color: #856404; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Mock Entra ID Sign-In</h1>
        <div class="notice">⚠ This is a local mock IdP for development only.</div>
        <form method="post" action="/saml/login-submit">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="error"></div>
            <label for="Email">Email</label>
            <input type="email" id="Email" name="Email" value="@Model.Email" placeholder="user@example.com" autocomplete="username" />
            <label for="Password">Password</label>
            <input type="password" id="Password" name="Password" autocomplete="current-password" />
            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>
